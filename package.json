{
  "name": "factory-island",
  "version": "0.2.0",
  "description": "A 2D factory-building game — mine, transport, process, automate.",
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --config vite.factory.config.ts",
    "build": "tsc --project tsconfig.factory.json && vite build --config vite.factory.config.ts",
    "preview": "vite preview --config vite.factory.config.ts",
    "lint": "eslint --quiet --ext .tsx,.ts .",
    "format": "npm run lint -- --fix",
    "test": "jest",
    "test:silent": "jest --silent --runInBand",
    "prepare": "husky install"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "phaser": "^3.80.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/jest": "^27.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "5.0.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^3.1.1",
    "husky": "^8.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.4.7",
    "lint-staged": ">=10",
    "prettier": "^3.3.2",
    "ts-jest": "^27.1.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "resolutions": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*": "prettier -u --write"
  }
}
